# Smart Finder AI Chatbot - Environment Variables
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env file to git (it's in .gitignore)

# ============================================
# LLM API Keys (Required - At least one)
# ============================================
# Gemini API Key (RECOMMENDED - 96% cheaper, better Google integration)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI API Key (Alternative/Fallback)
OPENAI_API_KEY=sk-your_openai_api_key

# ============================================
# Google Services API Keys
# ============================================
# Google Maps API Key (Required for Places search)
GOOGLE_MAPS_KEY=your_google_maps_api_key
# OR
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# YouTube Data API Key (Required for public video search)
YT_API_KEY=your_youtube_data_api_key
# OR
YOUTUBE_API_KEY=your_youtube_data_api_key

# ============================================
# OAuth Credentials (Required for platform connections)
# ============================================

# YouTube OAuth (Required to access user's saved/liked videos)
YT_OAUTH_CLIENT_ID=your_youtube_oauth_client_id
YT_OAUTH_CLIENT_SECRET=your_youtube_oauth_client_secret
# OR
YOUTUBE_CLIENT_ID=your_youtube_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_oauth_client_secret

# Instagram OAuth (Required to access user's media/reels)
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret

# Facebook OAuth (Required to access user's saved posts)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Google OAuth (Required for Timeline/Places features)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# ============================================
# OAuth Configuration
# ============================================
# OAuth Redirect Base URL (Your Firebase hosting URL)
OAUTH_REDIRECT_BASE=https://your-domain.web.app
# OR use default: https://buildkit-1695f.web.app

# ============================================
# Optional / Additional Services
# ============================================
# WhatsApp Integration (Optional)
WHATSAPP_TOKEN=your_whatsapp_token

# ============================================
# Firebase Functions Config (Alternative to .env)
# ============================================
# Instead of .env, you can also set these in Firebase Functions config:
#
# firebase functions:config:set gemini.key="YOUR_GEMINI_API_KEY"
# firebase functions:config:set openai.key="YOUR_OPENAI_API_KEY"
# firebase functions:config:set youtube.key="YOUR_YOUTUBE_API_KEY"
# firebase functions:config:set google.maps_key="YOUR_MAPS_API_KEY"
# firebase functions:config:set youtube.client_id="YOUR_CLIENT_ID"
# firebase functions:config:set youtube.client_secret="YOUR_CLIENT_SECRET"
# firebase functions:config:set instagram.client_id="YOUR_CLIENT_ID"
# firebase functions:config:set instagram.client_secret="YOUR_CLIENT_SECRET"
# firebase functions:config:set facebook.app_id="YOUR_APP_ID"
# firebase functions:config:set facebook.app_secret="YOUR_APP_SECRET"
# firebase functions:config:set google.client_id="YOUR_CLIENT_ID"
# firebase functions:config:set google.client_secret="YOUR_CLIENT_SECRET"
# firebase functions:config:set oauth.redirect_base="YOUR_REDIRECT_URL"
#
# Then deploy: firebase deploy --only functions
